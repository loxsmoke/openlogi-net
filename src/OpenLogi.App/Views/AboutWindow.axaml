<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenLogi.App.Views.AboutWindow"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/icon.png"
        Title="About OpenLogi.net">
    <StackPanel Margin="28" Spacing="10" HorizontalAlignment="Center">
        <Image Source="/Assets/icon.png" Width="72" Height="72" HorizontalAlignment="Center"
               RenderOptions.BitmapInterpolationMode="HighQuality"/>
        <TextBlock Text="OpenLogi.net" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock x:Name="VersionText" Opacity="0.7" HorizontalAlignment="Center"/>
        <TextBlock Text="A local-first alternative to Logitech Options+ for HID++ devices. No account, no telemetry."
                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320" Opacity="0.85"/>
        <StackPanel HorizontalAlignment="Center" Margin="0,4,0,0">
            <HyperlinkButton Content="GitHub" Click="OnGitHub" HorizontalAlignment="Center"/>
            <HyperlinkButton Content="Releases" Click="OnReleases" HorizontalAlignment="Center"/>
        </StackPanel>
        <TextBlock x:Name="SystemText" Opacity="0.55" FontSize="11" HorizontalAlignment="Center"
                   TextAlignment="Center" TextWrapping="Wrap" MaxWidth="340"/>
        <TextBlock x:Name="LogiWarningText" IsVisible="False" Foreground="#E3B341" FontSize="11"
                   TextAlignment="Center" TextWrapping="Wrap" MaxWidth="340" HorizontalAlignment="Center"/>
        <TextBlock Text="Licensed under MIT" Opacity="0.5" FontSize="11" HorizontalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,6,0,0">
            <Button x:Name="CopyButton" Content="Copy info" Click="OnCopy" MinWidth="100"
                    HorizontalContentAlignment="Center"/>
            <Button Content="Open logs" Click="OnOpenLogs" MinWidth="100"
                    HorizontalContentAlignment="Center"/>
            <Button Content="Close" Click="OnClose" MinWidth="84"
                    HorizontalContentAlignment="Center" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
